POSTGRES_USER=fintrack
POSTGRES_PASSWORD=fintrack
POSTGRES_DB=fintrack
POSTGRES_PORT=5432
WEB_PORT=3000

# Next.js on your host loads env from web/ — copy this file to web/.env (or duplicate keys there)
# when running: cd web && npm run dev

# For local Next.js outside Docker (host machine connects to published port):
# DATABASE_URL=postgresql://fintrack:fintrack@localhost:5432/fintrack

# Inside Docker Compose, DATABASE_URL is set in compose files (host: postgres).

# Session JWT (required for login; min 16 characters)
# JWT_SECRET=

# Optional: GitHub repository URL (header icon). Defaults to https://github.com if unset.
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername/fintrack
